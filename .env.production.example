# SerpentAI Production Environment Variables
# Copy this file to .env.production and configure for your environment
# WARNING: Never commit .env.production to version control!

# ==================== Application Configuration ====================

# Application name
APP_NAME=SerpentAI

# Application version
APP_VERSION=0.1.0-alpha

# Debug mode (MUST be false in production)
DEBUG=false

# Environment (development/staging/production)
ENVIRONMENT=production

# ==================== Paths Configuration ====================

# Base directory (usually /app in Docker)
BASE_DIR=/app

# Data directory (must be persistent volume)
DATA_DIR=/app/data

# Logs directory (must be persistent volume)
LOGS_DIR=/app/backend/logs

# Config directory
CONFIG_DIR=/app/config

# ==================== Database Configuration ====================

# SQLite URL (use file path for persistence)
SQLITE_URL=sqlite:///app/data/serpent_ai.db

# Chroma vector database persistence directory
CHROMA_PERSIST_DIR=/app/data/chroma

# Neo4j connection URI
NEO4J_URI=bolt://neo4j:7687

# Neo4j username
NEO4J_USER=neo4j

# Neo4j password (use Docker secrets in production)
NEO4J_PASSWORD=CHANGE_ME_immediately

# ==================== Redis Configuration ====================

# Redis host
REDIS_HOST=redis

# Redis port
REDIS_PORT=6379

# Redis database number
REDIS_DB=0

# Redis password (use Docker secrets in production)
REDIS_PASSWORD=CHANGE_ME_immediately

# ==================== Model Configuration ====================

# OpenAI API Key (use Docker secrets in production)
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE

# OpenAI API Base URL (change for proxies)
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic API Key (use Docker secrets in production)
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY_HERE

# Anthropic API Base URL
ANTHROPIC_API_BASE=https://api.anthropic.com

# ==================== Local Model Configuration ====================

# Local model directory (for Llama.cpp models)
LOCAL_MODEL_DIR=/app/models

# Llama.cpp thread count
LLAMA_CPP_THREADS=4

# Llama.cpp GPU layers (0 = CPU only, -1 = all GPU layers)
LLAMA_CPP_GPU_LAYERS=0

# ==================== Security Configuration ====================

# Secret key for JWT/sessions (MUST be changed in production)
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_secure_key

# Encryption key for sensitive data (MUST be changed in production)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_generate_secure_key

# Access token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== Memory System Configuration ====================

# Vector dimension (must match embedding model)
VECTOR_DIMENSION=384

# Similarity threshold for memory recall
SIMILARITY_THRESHOLD=0.7

# Maximum instant memories per session
MAX_INSTANT_MEMORIES=10

# Maximum short-term memories per session
MAX_SHORT_TERM_MEMORIES=1000

# Maximum long-term memories per session
MAX_LONG_TERM_MEMORIES=10000

# ==================== Token Optimization Configuration ====================

# Enable token optimization (precompilation + distillation)
ENABLE_TOKEN_OPTIMIZATION=true

# Prompt cache TTL (seconds)
PROMPT_CACHE_TTL=3600

# Enable tool ID mapping (reduces token usage)
TOOL_ID_MAPPING_ENABLED=true

# Context compression ratio (0.0-1.0)
CONTEXT_COMPRESSION_RATIO=0.7

# ==================== Multi-Agent Configuration ====================

# Maximum number of agents
MAX_AGENTS=10

# Agent communication timeout (seconds)
AGENT_COMMUNICATION_TIMEOUT=30

# ==================== Log Configuration ====================

# Log level (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=WARNING

# Log rotation size (e.g., 100 MB)
LOG_ROTATION=100 MB

# Log retention period (e.g., 30 days)
LOG_RETENTION=30 days

# Enable JSON logging (for ELK/Loki collection)
ENABLE_JSON_LOGGING=true

# ==================== Monitoring Configuration ====================

# Enable Prometheus metrics endpoint
ENABLE_METRICS=true

# Metrics endpoint port
METRICS_PORT=9090

# Enable request tracing
ENABLE_TRACING=true

# Tracing sample rate (0.0-1.0)
TRACING_SAMPLE_RATE=0.1

# ==================== Rate Limiting Configuration ====================

# Enable rate limiting
ENABLE_RATE_LIMITING=true

# Requests per minute per IP
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Requests per minute per user (authenticated)
RATE_LIMIT_USER_REQUESTS_PER_MINUTE=1000

# ==================== CORS Configuration ====================

# Allowed CORS origins (comma-separated)
# For production, specify exact origins (NO wildcards!)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Allowed CORS methods
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Allowed CORS headers
CORS_ALLOWED_HEADERS=*

# ==================== SSL/TLS Configuration ====================

# Enable HTTPS (recommended for production)
ENABLE_HTTPS=false

# SSL certificate path (if ENABLE_HTTPS=true)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem

# SSL private key path
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# ==================== Backup Configuration ====================

# Enable automatic backups
ENABLE_BACKUPS=true

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM

# Backup retention days
BACKUP_RETENTION_DAYS=30

# Backup storage path
BACKUP_PATH=/app/backups

# ==================== Webhook Configuration ====================

# Enable webhooks for events
ENABLE_WEBHOOKS=false

# Webhook URL (for sending events)
WEBHOOK_URL=https://your-webhook-url.com/events

# Webhook secret (for signature verification)
WEBHOOK_SECRET=CHANGE_ME_generate_webhook_secret

# ==================== Email Configuration (Optional) ====================

# SMTP server host
SMTP_HOST=smtp.gmail.com

# SMTP server port
SMTP_PORT=587

# SMTP username
SMTP_USERNAME=your-email@gmail.com

# SMTP password (use Docker secrets in production)
SMTP_PASSWORD=

# SMTP use TLS
SMTP_USE_TLS=true

# ==================== Performance Configuration ====================

# Worker processes (for Gunicorn)
GUNICORN_WORKERS=4

# Worker timeout (seconds)
GUNICORN_TIMEOUT=120

# Max requests before worker restart
GUNICORN_MAX_REQUESTS=1000

# Max requests jitter (randomizes restart)
GUNICORN_MAX_REQUESTS_JITTER=50

# ==================== Feature Flags ====================

# Enable self-evolution
ENABLE_SELF_EVOLUTION=true

# Enable tool learning
ENABLE_TOOL_LEARNING=true

# Enable multi-agent collaboration
ENABLE_MULTI_AGENT=true

# Enable voice interface
ENABLE_VOICE=false

# Enable workflow engine
ENABLE_WORKFLOW=true

# ==================== Usage Tracking ====================

# Track token usage
TRACK_TOKEN_USAGE=true

# Track API costs
TRACK_API_COSTS=true

# Cost alert threshold (USD)
COST_ALERT_THRESHOLD=100.0

# ==================== Docker Secrets Mapping ====================
# For production, use Docker secrets instead of environment variables:
#
# secrets:
#   - neo4j_password
#   - redis_password
#   - openai_api_key
#   - anthropic_api_key
#   - secret_key
#   - encryption_key
#
# Then reference in docker-compose.yml:
#   environment:
#     - NEO4J_PASSWORD_FILE=/run/secrets/neo4j_password
#   secrets:
#     - neo4j_password

# ==================== Example Docker Secrets Setup ====================
# 1. Create secrets directory:
#    mkdir -p secrets
#
# 2. Create secret files (WITHOUT newlines):
#    echo -n "your_secure_password" > secrets/neo4j_password.txt
#    echo -n "your_redis_password" > secrets/redis_password.txt
#    echo -n "sk-..." > secrets/openai_api_key.txt
#    echo -n "sk-ant-..." > secrets/anthropic_api_key.txt"
#    openssl rand -hex 32 > secrets/secret_key.txt
#    openssl rand -hex 32 > secrets/encryption_key.txt
#
# 3. Set proper permissions:
#    chmod 600 secrets/*
#
# 4. Add to .gitignore:
#    echo "secrets/" >> .gitignore
#    echo ".env.production" >> .gitignore
#
# 5. Use in docker-compose.prod.yml:
#    secrets:
#      - neo4j_password
#    ...
#    secrets:
#      neo4j_password:
#        file: ./secrets/neo4j_password.txt

# ==================== Security Checklist ====================
# BEFORE deploying to production:
#
# [ ] Changed NEO4J_PASSWORD from default
# [ ] Changed REDIS_PASSWORD from default
# [ ] Changed SECRET_KEY to secure random value
# [ ] Changed ENCRYPTION_KEY to secure random value
# [ ] Set DEBUG=false
# [ ] Set ENVIRONMENT=production
# [ ] Configured CORS_ALLOWED_ORIGINS with exact domains
# [ ] Enabled HTTPS (ENABLE_HTTPS=true)
# [ ] Set up Docker secrets for sensitive values
# [ ] Configured rate limiting (ENABLE_RATE_LIMITING=true)
# [ ] Set up monitoring (ENABLE_METRICS=true)
# [ ] Set up log collection (ENABLE_JSON_LOGGING=true)
# [ ] Configured backup schedule (ENABLE_BACKUPS=true)
# [ ] Reviewed and tested health check endpoint
# [ ] Set resource limits in docker-compose.prod.yml
# [ ] Enabled firewall (only expose necessary ports)
# [ ] Set up SSL/TLS certificates
# [ ] Configured log rotation and retention
# [ ] Set up alerting for critical errors
# [ ] Tested failure recovery (database restart, etc.)
# [ ] Reviewed and minimized exposed ports
# [ ] Ensured non-root user in Docker container
# [ ] Scanned Docker image for vulnerabilities
# [ ] Set up security headers in Nginx
# [ ] Configured request size limits
# [ ] Enabled CSRF protection (if applicable)
# [ ] Set up IP whitelisting/blacklisting (if needed)
