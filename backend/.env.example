# SerpentAI 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ==================== 应用基础配置 ====================
APP_NAME=SerpentAI
APP_VERSION=0.1.0-alpha
DEBUG=True
ENVIRONMENT=development  # development, production, testing

# ==================== 数据库配置 ====================
# SQLite (本地开发默认)
SQLITE_URL=sqlite+aiosqlite:///serpent_ai.db

# ChromaDB (向量数据库)
CHROMA_PERSIST_DIR=./data/chroma

# Neo4j (知识图谱)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=serpent_ai_2024

# ==================== Redis配置 (缓存与消息队列) ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== 模型配置 - OpenAI ====================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# ==================== 模型配置 - Anthropic ====================
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_API_BASE=https://api.anthropic.com

# ==================== 本地模型配置 ====================
LOCAL_MODEL_DIR=./models
LLAMA_CPP_THREADS=4
LLAMA_CPP_GPU_LAYERS=0  # 0表示仅CPU, >0表示使用GPU加速

# ==================== 安全配置 ====================
# 必须修改！用于生产环境
SECRET_KEY=your-super-secret-key-change-in-production
ENCRYPTION_KEY=your-encryption-key-change-in-production

# JWT Token配置
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== 记忆系统配置 ====================
VECTOR_DIMENSION=384  # sentence-transformers维度
SIMILARITY_THRESHOLD=0.7
MAX_SHORT_TERM_MEMORIES=1000
MAX_LONG_TERM_MEMORIES=10000

# ==================== Token优化配置 ====================
ENABLE_TOKEN_OPTIMIZATION=True
PROMPT_CACHE_TTL=3600  # 1小时
TOOL_ID_MAPPING_ENABLED=True
CONTEXT_COMPRESSION_RATIO=0.7

# ==================== 多智能体配置 ====================
MAX_AGENTS=10
AGENT_COMMUNICATION_TIMEOUT=30

# ==================== 日志配置 ====================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_ROTATION=100 MB
LOG_RETENTION=30 days

# ==================== 可选：邮件配置 ====================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_TLS=True

# ==================== 可选：Webhook配置 ====================
# WEBHOOK_SECRET=your-webhook-secret
# ALLOWED_WEBHOOK_IPS=127.0.0.1,::1

# ==================== 可选：IM平台配置 ====================
# 微信
# WECHAT_APP_ID=your-app-id
# WECHAT_APP_SECRET=your-app-secret

# Telegram
# TELEGRAM_BOT_TOKEN=your-bot-token

# Discord
# DISCORD_BOT_TOKEN=your-bot-token

# Slack
# SLACK_BOT_TOKEN=your-bot-token
# SLACK_SIGNING_SECRET=your-signing-secret

# ==================== 可选：监控配置 ====================
# SENTRY_DSN=your-sentry-dsn
# PROMETHEUS_ENABLED=False
# PROMETHEUS_PORT=9090
