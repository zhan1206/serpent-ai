# SerpentAI 环境配置模板
# 复制此文件为 .env 并填写实际值

# ==================== 模型配置 ====================

# OpenAI 配置
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1  # 可选：自定义端点

# Anthropic 配置
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_API_BASE=https://api.anthropic.com  # 可选：自定义端点

# Llama.cpp 配置（本地模型）
LLAMA_CPP_THREADS=4  # CPU 线程数
LLAMA_CPP_GPU_LAYERS=0  # GPU 加速层数（0=仅CPU）
LLAMA_MODEL_PATH=/path/to/your/model.gguf  # 模型文件路径


# ==================== 数据库配置 ====================

# SQLite（默认，无需配置）
# 数据库文件：data/serpent-ai.db

# ChromaDB（向量数据库，可选）
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_PERSIST_DIR=./data/chromadb

# Neo4j（知识图谱，可选）
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here


# ==================== 安全配置 ====================

# 密钥（用于加密敏感数据）
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32

# JWT 配置（用于 API 认证）
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API 密钥（用于访问 SerpentAI API）
API_KEYS=key1-value,key2-value


# ==================== 服务器配置 ====================

# 主机和端口
HOST=0.0.0.0
PORT=8000

# 调试模式
DEBUG=false
LOG_LEVEL=INFO


# ==================== 工具配置 ====================

# MCP（模型上下文协议）配置
MCP_SERVER_URL=http://localhost:9000
MCP_AUTH_TOKEN=your-mcp-token-here

# 沙箱配置（工具执行环境）
SANDBOX_MODE=docker  # 可选：subprocess, docker, gvisor
SANDBOX_TIMEOUT=30  # 工具执行超时（秒）
SANDBOX_MEMORY_LIMIT=512  # 内存限制（MB）


# ==================== 缓存配置 ====================

# Redis（可选，用于分布式缓存）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-here
REDIS_DB=0

# 缓存策略
CACHE_STRATEGY=two-tier  # 可选：memory, redis, two-tier
CACHE_TTL=3600  # 默认缓存时间（秒）


# ==================== 监控配置 ====================

# Prometheus（可选）
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# OpenTelemetry（可选）
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317


# ==================== 其他配置 ====================

# 工作目录
WORKSPACE_DIR=./workspace

# 插件目录
PLUGINS_DIR=./plugins

# 日志目录
LOGS_DIR=./logs

# 最大上传文件大小（MB）
MAX_UPLOAD_SIZE=100

# CORS 允许的来源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
